# Git ignore rules for Test-Series project

# ── Environment files ───────────────────────────────────────
.env
.env.local
.env.production
.env.prod
backend/.env
backend/.env.local
backend/.env.production
backend/.env.prod
**/node_modules/

# ── Build outputs ────────────────────────────────────────────
frontend/dist/

# ── Uploads (user content) ───────────────────────────────────
backend/uploads/

# ── OS files ─────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Logs ─────────────────────────────────────────────────────
*.log
npm-debug.log*

# ── IDE ──────────────────────────────────────────────────────
.vscode/
.idea/
